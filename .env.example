# Codex Lector — OAuth Configuration
# Copy this file to .env and fill in your credentials.
#
# You only need to configure the providers you want to enable.
# Any provider left blank will not appear on the sign-in screen.

# JWT secret (change this to something random in production)
JWT_SECRET=codex-lector-change-me-in-production

# Base URL (used for OAuth callbacks — no trailing slash)
BASE_URL=http://localhost:3001

# Public site URL (used for RSS, sitemap, OG tags — no trailing slash)
SITE_URL=http://localhost:3001

# ─── Google OAuth ───
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {BASE_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── GitHub OAuth ───
# Create at: https://github.com/settings/developers → New OAuth App
# Authorization callback URL: {BASE_URL}/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── X (Twitter) OAuth ───
# Create at: https://developer.x.com/en/portal/projects
# Callback URL: {BASE_URL}/api/auth/twitter/callback
TWITTER_CONSUMER_KEY=
TWITTER_CONSUMER_SECRET=
